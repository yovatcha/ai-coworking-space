generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  userId    String
  npcId     String
  role      String
  content   String
  createdAt DateTime @default(now())
}

model SheetEntry {
  id        Int      @id @default(autoincrement())
  userId    String
  name      String
  sheetId   String
  scriptUrl String
  columns   String
  createdAt DateTime @default(now())
}
