# ── Vercel (frontend) ──────────────────────────────────────────
# URL of your Railway Socket.IO backend
NEXT_PUBLIC_SOCKET_URL=https://your-app.railway.app

# ── Railway (backend) ──────────────────────────────────────────
# Allow requests from your Vercel frontend
FRONTEND_URL=https://your-app.vercel.app

# Port is set automatically by Railway — no need to set it manually
# PORT=3001

OPENROUTER_API_KEY=

ROOM_PASSWORD=